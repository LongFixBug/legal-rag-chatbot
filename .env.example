APP_NAME="RAG Legal Assistant"
APP_VERSION="0.2.0"
API_PREFIX="/api"
STORAGE_DIR=".storage"
DATA_DIR="data"
PRELOAD_SAMPLE_DATA="true"
EMBEDDING_DIMENSION="1024"
TOP_K="4"
MAX_HISTORY_MESSAGES="6"
LEXICAL_WEIGHT="0.35"
ARTICLE_REFERENCE_BOOST="0.75"
TITLE_MATCH_BOOST="0.2"

DATABASE_URL="postgresql+asyncpg://raguser:ragpass@localhost:5433/ragdb"
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="legal_chunks_qwen3"

LLM_BASE_URL="http://localhost:8080"
LLM_API_KEY=""
LLM_MODEL="qwen2.5-7b-instruct"
EMBEDDING_BASE_URL="http://localhost:8081"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="qwen3-embedding-0.6b"
