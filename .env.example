APP_NAME="Military Service Law RAG Assistant"
APP_VERSION="0.2.0"
API_PREFIX="/api"
STORAGE_DIR=".storage"
DATA_DIR="data"
PRELOAD_SAMPLE_DATA="true"
PRELOAD_INCLUDE_PATTERN="nghia-vu-quan-su-curated-*.txt"
EMBEDDING_DIMENSION="1024"
TOP_K="4"
MAX_HISTORY_MESSAGES="6"
LEXICAL_WEIGHT="0.35"
ARTICLE_REFERENCE_BOOST="0.75"
TITLE_MATCH_BOOST="0.2"
MIN_RETRIEVAL_CONFIDENCE="0.2"
ADMIN_TOKEN=""
RATE_LIMIT_ENABLED="true"
CHAT_RATE_LIMIT_PER_MINUTE="30"
DOCUMENT_MUTATION_RATE_LIMIT_PER_MINUTE="12"
MAX_UPLOAD_BYTES="5242880"
ALLOWED_UPLOAD_EXTENSIONS=".txt,.md,.html,.htm,.pdf"
ALLOWED_UPLOAD_MIME_TYPES="text/plain,text/markdown,text/html,application/pdf"
PARSER_VERSION="parser.v1"
CHUNKING_VERSION="legal-article-chunker.v1"
UPLOADED_DOCUMENT_RETENTION_DAYS="0"
CHAT_HISTORY_RETENTION_DAYS="0"

DATABASE_URL="postgresql+asyncpg://raguser:ragpass@localhost:5433/ragdb"
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="legal_chunks_qwen3"

LLM_BASE_URL="http://localhost:8080"
LLM_API_KEY=""
LLM_MODEL="qwen2.5-7b-instruct-q4_k_m.gguf"
LLM_TIMEOUT_SECONDS="60"
LLM_MAX_RETRIES="1"
EMBEDDING_BASE_URL="http://localhost:8081"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="Qwen3-Embedding-0.6B-Q8_0.gguf"
